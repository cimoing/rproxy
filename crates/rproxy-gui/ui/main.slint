import { ListView, VerticalBox, HorizontalBox } from "std-widgets.slint";

export struct NodeRow {
    index: int,
    name: string,
    server: string,
    protocol: string,
}

component AppButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary;
    callback clicked();

    height: 34px;
    min-width: 96px;
    border-radius: 4px;
    border-width: 1px;
    border-color: root.primary ? #256f8f : #aeb9c6;
    background: touch.pressed ? #cad8e6 : (touch.has-hover ? #dde8f3 : (root.primary ? #d0e8f3 : #edf2f7));

    Text {
        text: root.text;
        color: #17202a;
        font-weight: root.primary ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component FormInput inherits Rectangle {
    in-out property <string> text;

    height: 32px;
    border-radius: 4px;
    border-width: 1px;
    border-color: input.has-focus ? #2f7fa4 : #aeb9c6;
    background: #f8fafc;

    input := TextInput {
        x: 9px;
        y: 1px;
        width: parent.width - 18px;
        height: parent.height - 2px;
        text <=> root.text;
        color: #17202a;
        selection-background-color: #b9d9ea;
        vertical-alignment: center;
        single-line: true;
    }
}

component SelectBox inherits Rectangle {
    in-out property <string> value;
    in property <[string]> options;
    property <bool> open;

    height: 32px;
    clip: false;

    Rectangle {
        height: 32px;
        border-radius: 4px;
        border-width: 1px;
        border-color: root.open ? #2f7fa4 : #aeb9c6;
        background: touch.has-hover ? #edf4fa : #f8fafc;

        Text {
            x: 9px;
            width: parent.width - 34px;
            height: parent.height;
            text: root.value;
            color: #17202a;
            vertical-alignment: center;
        }

        Text {
            x: parent.width - 24px;
            width: 16px;
            height: parent.height;
            text: root.open ? "▲" : "▼";
            color: #425466;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        touch := TouchArea {
            clicked => {
                root.open = !root.open;
            }
        }
    }

    if root.open : Rectangle {
        y: 34px;
        z: 50;
        width: parent.width;
        height: root.options.length * 30px;
        border-radius: 4px;
        border-width: 2px;
        border-color: #2f7fa4;
        background: #d8e6f0;

        VerticalBox {
            for option in root.options : Rectangle {
                height: 30px;
                background: row-touch.has-hover ? #bcd7ea : (option == root.value ? #a8cee3 : #d8e6f0);

                Text {
                    x: 9px;
                    width: parent.width - 18px;
                    height: parent.height;
                    text: option;
                    color: #17202a;
                    vertical-alignment: center;
                }

                row-touch := TouchArea {
                    clicked => {
                        root.value = option;
                        root.open = false;
                    }
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "RProxy";
    width: 900px;
    height: 620px;
    default-font-size: 14px;

    in-out property <string> status;
    in-out property <bool> running;
    in-out property <[NodeRow]> nodes;
    in-out property <bool> editor-open;
    in-out property <int> edit-index: -1;
    in-out property <string> edit-title;
    in-out property <string> edit-name;
    in-out property <string> edit-server;
    in-out property <string> edit-port;
    in-out property <string> edit-protocol;
    in-out property <string> edit-username;
    in-out property <string> edit-password;
    in-out property <string> edit-uuid;
    in-out property <bool> edit-tls;
    in-out property <string> edit-transport;
    in-out property <string> edit-ws-path;

    callback toggle-proxy();
    callback open-pac(string);
    callback add-node();
    callback edit-node(int);
    callback save-node(int, string, string, string, string, string, string, string, bool, string, string);
    callback cancel-edit();

    property <color> primary-text: #17202a;
    property <color> secondary-text: #425466;
    property <color> panel-background: #f3f6fa;
    property <color> page-background: #e9eef5;
    property <color> row-background: #f8fafc;
    property <bool> proxy-protocol: root.edit-protocol == "vless" || root.edit-protocol == "vmess";
    property <bool> auth-protocol: root.edit-protocol == "http" || root.edit-protocol == "socks5";
    property <bool> websocket-transport: root.edit-transport == "websocket";

    Rectangle {
        background: root.page-background;

        VerticalBox {
            padding: 24px;
            spacing: 14px;

            HorizontalBox {
                spacing: 12px;

                Text {
                    text: "RProxy";
                    font-size: 28px;
                    font-weight: 700;
                    color: root.primary-text;
                    horizontal-stretch: 1;
                }

                AppButton {
                    text: "添加节点";
                    primary: true;
                    clicked => {
                        root.add-node();
                    }
                }

                AppButton {
                    text: root.running ? "停止代理" : "启动代理";
                    primary: false;
                    clicked => {
                        root.toggle-proxy();
                    }
                }

                AppButton {
                    text: "打开 PAC";
                    primary: false;
                    clicked => {
                        root.open-pac("http://127.0.0.1:7892/proxy.pac");
                    }
                }
            }

            Text {
                text: root.status;
                color: #315b7a;
            }

            VerticalBox {
                spacing: 8px;

                HorizontalBox {
                    height: 32px;
                    spacing: 8px;
                    padding-left: 8px;
                    padding-right: 8px;

                    Text { text: "名称"; font-weight: 700; color: root.primary-text; width: 180px; }
                    Text { text: "域名"; font-weight: 700; color: root.primary-text; horizontal-stretch: 1; }
                    Text { text: "协议"; font-weight: 700; color: root.primary-text; width: 96px; }
                }

                Rectangle {
                    height: 1px;
                    background: #d8dee5;
                }

                ListView {
                    height: 430px;

                    for node in root.nodes : Rectangle {
                        height: 44px;
                        background: touch.has-hover ? #dfeaf6 : root.row-background;

                        HorizontalBox {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 8px;

                            Text { text: node.name; color: root.primary-text; width: 180px; vertical-alignment: center; }
                            Text { text: node.server; color: root.secondary-text; horizontal-stretch: 1; vertical-alignment: center; }
                            Text { text: node.protocol; color: root.primary-text; width: 96px; vertical-alignment: center; }
                        }

                        touch := TouchArea {
                            pointer-event(event) => {
                                if event.kind == PointerEventKind.down && event.button == PointerEventButton.right {
                                    root.edit-node(node.index);
                                }
                            }
                            clicked => {
                                root.edit-node(node.index);
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            visible: root.editor-open;
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: #00000066;

            Rectangle {
                width: 460px;
                height: 500px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                background: root.panel-background;
                border-color: #d8dee5;
                border-width: 1px;
                border-radius: 6px;

                VerticalBox {
                    padding: 20px;
                    spacing: 10px;

                    Text {
                        text: root.edit-title;
                        font-size: 18px;
                        font-weight: 700;
                        color: root.primary-text;
                    }

                    HorizontalBox {
                        height: 36px;
                        spacing: 12px;
                        Text { text: "名称"; color: root.primary-text; width: 112px; horizontal-alignment: right; vertical-alignment: center; }
                        FormInput { text <=> root.edit-name; horizontal-stretch: 1; }
                    }

                    HorizontalBox {
                        height: 36px;
                        spacing: 12px;
                        Text { text: "域名"; color: root.primary-text; width: 112px; horizontal-alignment: right; vertical-alignment: center; }
                        FormInput { text <=> root.edit-server; horizontal-stretch: 1; }
                    }

                    HorizontalBox {
                        height: 36px;
                        spacing: 12px;
                        Text { text: "端口"; color: root.primary-text; width: 112px; horizontal-alignment: right; vertical-alignment: center; }
                        FormInput { text <=> root.edit-port; horizontal-stretch: 1; }
                    }

                    HorizontalBox {
                        height: 36px;
                        spacing: 12px;
                        z: 20;
                        Text { text: "协议"; color: root.primary-text; width: 112px; horizontal-alignment: right; vertical-alignment: center; }
                        SelectBox {
                            options: ["vmess", "vless", "http", "socks5"];
                            value <=> root.edit-protocol;
                            horizontal-stretch: 1;
                        }
                    }

                    if root.auth-protocol : HorizontalBox {
                        height: 36px;
                        spacing: 12px;
                        Text { text: "用户名"; color: root.primary-text; width: 112px; horizontal-alignment: right; vertical-alignment: center; }
                        FormInput { text <=> root.edit-username; horizontal-stretch: 1; }
                    }

                    if root.auth-protocol : HorizontalBox {
                        height: 36px;
                        spacing: 12px;
                        Text { text: "密码"; color: root.primary-text; width: 112px; horizontal-alignment: right; vertical-alignment: center; }
                        FormInput { text <=> root.edit-password; horizontal-stretch: 1; }
                    }

                    if root.proxy-protocol : HorizontalBox {
                        height: 36px;
                        spacing: 12px;
                        Text { text: "UUID"; color: root.primary-text; width: 112px; horizontal-alignment: right; vertical-alignment: center; }
                        FormInput { text <=> root.edit-uuid; horizontal-stretch: 1; }
                    }

                    if root.proxy-protocol : HorizontalBox {
                        height: 36px;
                        spacing: 12px;
                        Text { text: "TLS"; color: root.primary-text; width: 112px; horizontal-alignment: right; vertical-alignment: center; }
                        Rectangle {
                            width: 54px;
                            height: 28px;
                            border-radius: 14px;
                            border-width: 1px;
                            border-color: root.edit-tls ? #256f8f : #8fa0b2;
                            background: root.edit-tls ? #2f7fa4 : (tls-touch.has-hover ? #dfe8f1 : #eef3f8);

                            Rectangle {
                                width: 22px;
                                height: 22px;
                                x: root.edit-tls ? parent.width - self.width - 3px : 3px;
                                y: 3px;
                                border-radius: 11px;
                                background: #f8fafc;
                                border-width: 1px;
                                border-color: root.edit-tls ? #18536d : #8fa0b2;
                            }

                            tls-touch := TouchArea {
                                clicked => {
                                    root.edit-tls = !root.edit-tls;
                                }
                            }
                        }
                    }

                    if root.proxy-protocol : HorizontalBox {
                        height: 36px;
                        spacing: 12px;
                        z: 18;
                        Text { text: "传输"; color: root.primary-text; width: 112px; horizontal-alignment: right; vertical-alignment: center; }
                        SelectBox {
                            options: ["websocket", "tcp"];
                            value <=> root.edit-transport;
                            horizontal-stretch: 1;
                        }
                    }

                    if root.proxy-protocol && root.websocket-transport : HorizontalBox {
                        height: 36px;
                        spacing: 12px;
                        Text { text: "WS Path"; color: root.primary-text; width: 112px; horizontal-alignment: right; vertical-alignment: center; }
                        FormInput { text <=> root.edit-ws-path; horizontal-stretch: 1; }
                    }

                    HorizontalBox {
                        height: 36px;
                        spacing: 8px;
                        alignment: end;

                        AppButton {
                            text: "保存";
                            primary: true;
                            clicked => {
                                root.save-node(root.edit-index, root.edit-name, root.edit-server, root.edit-port, root.edit-protocol, root.edit-username, root.edit-password, root.edit-uuid, root.edit-tls, root.edit-transport, root.edit-ws-path);
                            }
                        }

                        AppButton {
                            text: "取消";
                            primary: false;
                            clicked => {
                                root.cancel-edit();
                            }
                        }
                    }
                }
            }
        }
    }
}
